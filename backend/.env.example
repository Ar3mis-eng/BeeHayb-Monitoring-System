# Server Configuration
NODE_ENV=production
PORT=5000

# Security
JWT_SECRET=change_this_to_a_long_random_secret

# CORS (comma-separated list, or * for development only)
CORS_ORIGIN=https://your-mobile-api-consumer.example.com

# PostgreSQL (Supabase/Cloud preferred)
# Preferred: full connection string from Supabase
DATABASE_URL=postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres

# SSL for managed Postgres providers (Supabase)
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Optional local fallback settings (used only if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beehayb
DB_USER=postgres
DB_PASSWORD=postgres

# MQTT Configuration (HiveMQ Cloud)
# Example: mqtts://xxxxxxxxxxxx.s1.eu.hivemq.cloud:8883
MQTT_BROKER=mqtts://your-hivemq-host:8883
MQTT_USER=your_hivemq_username
MQTT_PASS=your_hivemq_password
MQTT_CLIENT_ID=beehayb-backend
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=30000
MQTT_KEEPALIVE_SECONDS=60
MQTT_CLEAN=true
MQTT_REJECT_UNAUTHORIZED=true
