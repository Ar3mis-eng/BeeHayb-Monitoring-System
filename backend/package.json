{
  "name": "beehayb-backend",
  "version": "1.0.0",
  "description": "Backend for BeeHayb Smart Beehive Monitoring System",
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node src/database/seed.ts",
    "create-admin": "ts-node src/database/createAdmin.ts",
    "migrate": "psql -U postgres -d beehayb -f ../database/schema.sql"
  },
  "keywords": [
    "beehive",
    "monitoring",
    "iot",
    "mqtt",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jwt-simple": "^0.5.6",
    "mqtt": "^4.3.7",
    "pg": "^8.8.0",
    "socket.io": "^4.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^18.11.18",
    "@types/pg": "^8.9.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.9.4"
  }
}
